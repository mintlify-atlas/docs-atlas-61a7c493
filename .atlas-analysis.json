  "keyFeatures": [
    "Multi-role access control (Admin, Revisor, Postulante, Simulacro, Calificador, Segundas)",
    "Step-by-step applicant registration and document submission portal",
    "Document review and approval workflow with real-time notifications (Firebase/FCM)",
    "Biometric data capture and verification (fingerprints and photos)",
    "Exam simulation management and scoring module",
    "Segundas Especialidades admission process",
    "PDF generation for admission certificates, credentials, and biometric records",
    "Excel/XLSX import and export for results and reports",
    "Google OAuth login integration via Laravel Socialite",
    "RENIEC identity verification integration",
    "Bank payment verification via voucher lookup",
    "Audit trail for all critical administrative actions",
    "Electronic signature support for institutional documents",
    "Inertia.js SPA with Vue 3 and Ant Design Vue components"
  ],
